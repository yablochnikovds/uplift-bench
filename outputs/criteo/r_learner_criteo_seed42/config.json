{
  "base_learner": {
    "name": "catboost",
    "params": {
      "depth": 6,
      "iterations": 500,
      "learning_rate": 0.05
    }
  },
  "bootstrap": {
    "alpha": 0.05,
    "method": "bca",
    "n_boot": 300,
    "n_jobs": 1,
    "seed": 42
  },
  "dataset": {
    "data_dir": "data/raw",
    "loader_params": {
      "outcome": "visit",
      "subsample": 1000000,
      "subsample_seed": 42
    },
    "name": "criteo"
  },
  "model": {
    "extra_params": {
      "n_splits": 5
    },
    "name": "r_learner"
  },
  "robustness": {
    "enable_overlap": true,
    "enable_permutation": false,
    "permutation_n_repeats": 5
  },
  "seed": 42,
  "split": {
    "seed": 42,
    "train_frac": 0.7,
    "val_frac": 0.15
  }
}